# These variables belong in the SHARED ROOT .env at the repo root
# (../../.env relative to this file). The sweep bot loads that file
# at startup; it does NOT read a local .env in this subdirectory.
#
# Append the keys below to the shared .env on the droplet.

# OpenSea Stream API key (https://opensea.io/settings/developer)
OPENSEA_API_KEY=

# X / Twitter OAuth 1.0a user-context credentials (4-key set required
# for media upload via twitter-api-v2)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Operational flags
DRY_RUN=false
STREAM_LOG_ONLY=false

# Big-wins listener (WSS on ApeChain). Same APECHAIN_WSS_URL that notify.js
# already uses — Alchemy WSS endpoint.
APECHAIN_WSS_URL=
