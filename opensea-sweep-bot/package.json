{
  "name": "opensea-sweep-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Watches a deployer wallet for OpenSea sweeps on Ethereum and ApeChain and posts announcements to X.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@opensea/stream-js": "^0.3.0",
    "@supabase/supabase-js": "^2.105.4",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.5",
    "node-localstorage": "^3.0.5",
    "sharp": "^0.33.5",
    "twitter-api-v2": "^1.19.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/node-localstorage": "^1.3.3",
    "@types/phoenix": "^1.6.6",
    "@types/ws": "^8.5.13",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
